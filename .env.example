# Host-development defaults. Docker Compose overrides database, data, model,
# and embedding addresses with container-internal values automatically.
PAPER_RAG_POSTGRES_DSN=postgresql+psycopg://paper_rag:paper_rag@127.0.0.1:5433/paper_rag
PAPER_RAG_UPLOAD_DIR=data/uploads
PAPER_RAG_PARSED_DIR=data/parsed
PAPER_RAG_CHROMA_DIR=data/chroma
PAPER_RAG_MAX_UPLOAD_BYTES=20971520
PAPER_RAG_MAX_PDF_PAGES=200
PAPER_RAG_QUEUE_MAXSIZE=32
PAPER_RAG_CHUNK_TARGET_CHARS=1400
PAPER_RAG_CHUNK_OVERLAP_CHARS=180
PAPER_RAG_EMBEDDING_MODEL_ID=BAAI/bge-m3
PAPER_RAG_EMBEDDING_MODEL_PATH=models/BAAI-bge-m3
PAPER_RAG_EMBEDDING_DIMENSION=1024
PAPER_RAG_EMBEDDING_DEVICE=auto
PAPER_RAG_EMBEDDING_BATCH_SIZE=4
PAPER_RAG_EMBEDDING_MAX_SEQ_LENGTH=2048
PAPER_RAG_RETRIEVAL_MIN_SCORE=0.50
PAPER_RAG_DEEPSEEK_BASE_URL=https://api.deepseek.com
PAPER_RAG_DEEPSEEK_MODEL=deepseek-v4-flash
PAPER_RAG_DEEPSEEK_TIMEOUT_SECONDS=90
PAPER_RAG_DEEPSEEK_KEY_TTL_SECONDS=3600
PAPER_RAG_DEEPSEEK_MAX_RETRIES=2
PAPER_RAG_DEEPSEEK_THINKING_REWRITE=false
PAPER_RAG_DEEPSEEK_THINKING_SCHEMA_REPAIR=false
PAPER_RAG_DEEPSEEK_THINKING_EXTRACT=false
PAPER_RAG_DEEPSEEK_THINKING_SYNTHESIS=true
PAPER_RAG_DEEPSEEK_THINKING_AUDIT=true
PAPER_RAG_DEEPSEEK_THINKING_HYPOTHESIS=true
PAPER_RAG_PROMPT_VERSION=grounded-answer-v1
PAPER_RAG_EMBEDDING_PROVIDER=http
PAPER_RAG_EMBEDDING_SERVICE_URL=http://127.0.0.1:8011
